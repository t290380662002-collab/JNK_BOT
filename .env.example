# Telegram BotFather 取得的 token
TELEGRAM_BOT_TOKEN=123456789:ABCDEFGHIJKLMNOPQRSTUVWXYZ

# Render 部署時會自動填入你的 app 網址，例如 https://docscan-bot.onrender.com
# 留空則使用 polling 模式（適合本地測試）
WEBHOOK_URL=

# 雲端 OCR 備援：none / google / azure
OCR_PROVIDER=none

# 僅當 OCR_PROVIDER=google 時需要
GOOGLE_VISION_API_KEY=

# 僅當 OCR_PROVIDER=azure 時需要
AZURE_VISION_ENDPOINT=
AZURE_VISION_KEY=
